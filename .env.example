# SFTP server where jobs and files are stored
VOD_SFTP_HOST=10.0.0.12
VOD_SFTP_PORT=22
VOD_SFTP_USER=vod

# Auth: set key path, password, or both (key is tried first)
VOD_SFTP_KEY_PATH=/home/youruser/.ssh/id_ed25519
VOD_SFTP_PASSWORD=

# Base directory on the SFTP server (must exist)
VOD_SFTP_BASE_PATH=/home/vod/vod_studio

# API server (only needed if running api.py)
VOD_API_HOST=0.0.0.0
VOD_API_PORT=8000

# Worker tuning
VOD_POLL_INTERVAL=5        # seconds between job polls
VOD_HEARTBEAT_INTERVAL=10  # seconds between heartbeats
VOD_WORKER_TIMEOUT=60      # seconds before a worker is considered dead
